{
    "frameworkId": "david-travis-ux-v1",
    "name": "UX Competency Framework",
    "author": "David Travis",
    "scale": {
      "1": "Novice",
      "2": "Advanced Beginner",
      "3": "Competent",
      "4": "Proficient",
      "5": "Expert"
    },
    "categories": [
      {
        "id": "user-research",
        "label": "User Research",
        "behaviours": [
          { "id": "articulate-importance-user-research", "text": "Articulate the importance of user research, not just before the system is designed but also during design and after deployment." },
          { "id": "identify-potential-users", "text": "Identify the potential users of the system." },
          { "id": "plan-site-visits-end-users", "text": "Plan site visits to end users, including deciding who to sample." },
          { "id": "structure-effective-interview", "text": "Structure an effective interview that gets beyond the surface opinions (what users say) to reveal user goals (what users want)." },
          { "id": "keep-appropriate-records", "text": "Keep appropriate records of each observation." },
          { "id": "analyse-qualitative-data-site-visit", "text": "Analyse qualitative data from a site visit." },
          { "id": "present-data-site-visit", "text": "Present the data from a site visit in ways that can be used to drive design: for example, personas, user stories, user journey maps." },
          { "id": "analyse-interpret-existing-data", "text": "Analyse and interpret existing data (for example web analytics, user surveys, customer support calls)." },
          { "id": "critically-evaluate-previous-user-research", "text": "Critically evaluate previous user research." }
        ]
      },
      {
        "id": "usability-eval",
        "label": "Usability Evaluation",
        "behaviours": [
          { "id": "plan-moderate-usability-tests", "text": "Plan and moderate usability tests" },
          { "id": "conduct-expert-heuristic-reviews", "text": "Conduct expert/heuristic reviews" },
          { "id": "analyse-report-usability-findings", "text": "Analyse and report usability findings" },
          { "id": "measure-task-success-time-on-task", "text": "Measure task success and time-on-task" }
        ]
      },
      {
        "id": "info-arch",
        "label": "Information Architecture",
        "behaviours": [
          { "id": "create-sitemaps-navigation-flows", "text": "Create sitemaps and navigation flows" },
          { "id": "conduct-card-sorting-exercises", "text": "Conduct card sorting exercises" },
          { "id": "design-taxonomy-labelling-systems", "text": "Design taxonomy and labelling systems" },
          { "id": "organise-complex-content-structures", "text": "Organise complex content structures" }
        ]
      },
      {
        "id": "int-design",
        "label": "Interaction Design",
        "behaviours": [
          { "id": "create-wireframes-interactive-prototypes", "text": "Create wireframes and interactive prototypes" },
          { "id": "design-accessibility-inclusivity", "text": "Design for accessibility and inclusivity" },
          { "id": "define-ui-patterns-design-systems", "text": "Define UI patterns and design systems" },
          { "id": "specify-micro-interactions-transitions", "text": "Specify micro-interactions and transitions" }
        ]
      },
      {
        "id": "visual-design",
        "label": "Visual Design",
        "behaviours": [
          { "id": "apply-colour-theory-typography", "text": "Apply colour theory and typography" },
          { "id": "create-high-fidelity-ui-mockups", "text": "Create high-fidelity UI mockups" },
          { "id": "ensure-brand-consistency-across-touchpoints", "text": "Ensure brand consistency across touchpoints" },
          { "id": "design-different-screen-densities", "text": "Design for different screen densities (Retina/OLED)" }
        ]
      },
      {
        "id": "writing",
        "label": "Technical Writing",
        "behaviours": [
          { "id": "write-clear-microcopy-ui-labels", "text": "Write clear microcopy and UI labels" },
