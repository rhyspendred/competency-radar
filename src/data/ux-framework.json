        ]
      },
      {
        "id": "management",
        "label": "UX Management",
        "behaviours": [
          { "id": "mentor-junior-designers", "text": "Mentor junior designers" },
          { "id": "stay-updated-industry-trends", "text": "Stay updated on industry trends" },
          { "id": "contribute-design-community", "text": "Contribute to the design community" },
          { "id": "manage-project-timelines-budgets", "text": "Manage project timelines and budgets" }
